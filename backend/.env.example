# ---- Core ----
PORT=5000
MONGO_URI=your_mongodb_connection_string_here

# Must be at least 32 characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed browser origins.
CLIENT_URL=http://localhost:5173

# ---- Email verification ----
# Set to false only for local development without a working SMTP setup.
# Leaving it unset (or true) requires users to confirm their email before
# logging in or placing an order.
REQUIRE_EMAIL_VERIFICATION=true

# ---- SMTP (needed for verification, password reset, order receipts) ----
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_app_password

# ---- Admin bootstrap (used only by `npm run create-admin`) ----
ADMIN_NAME=Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=use_a_long_random_password_here

# ---- Payments (Razorpay) ----
# Leave unset to run in cash-on-delivery mode; the UI hides online payment.
# Test keys: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# A separate secret, set when you register the webhook endpoint.
RAZORPAY_WEBHOOK_SECRET=

# ---- Redis (optional) ----
# Unset: in-memory cache, per-process rate limits, single-instance Socket.io.
# Set:   shared cache, global rate limits, and multi-instance Socket.io.
REDIS_URL=

# ---- Logging ----
# trace | debug | info | warn | error | fatal
# Defaults: debug in development, info in production, silent in tests.
LOG_LEVEL=

# ---- Image uploads (Cloudinary, optional) ----
# Unset: the admin UI falls back to entering an image URL by hand.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- AI support assistant (optional) ----
# Unset: the chat widget behaves as before and staff answer every message.
# Set:   the assistant answers first, using tools that read live menu, order
#        and loyalty data, and escalates to staff when it cannot help.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ---- Web Push notifications (optional) ----
# Unset: the app never offers to enable notifications.
# Generate a key pair with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@bharadwajscafe.com
